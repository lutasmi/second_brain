# --- Telegram (obligatorio para `second-brain run`) -------------------------
# 1. Habla con @BotFather en Telegram → /newbot → copia el token.
TELEGRAM_BOT_TOKEN=

# 2. Tu id numérico de usuario (habla con @userinfobot para conocerlo).
#    Varios ids separados por comas. Si lo dejas vacío, CUALQUIERA podrá
#    escribir en tu biblioteca — no lo dejes vacío.
TELEGRAM_ALLOWED_USER_IDS=

# --- Biblioteca --------------------------------------------------------------
# Directorio donde viven los Markdown (la fuente de verdad).
LIBRARY_DIR=library

# --- IA: descripción de imágenes y auto-etiquetado (opcional) ----------------
# Sin clave, todo se captura igualmente: las imágenes quedan `pending` (se
# completan con `reprocess` al añadir la clave) y las notas no llevan
# etiquetas automáticas. Con AI_PROVIDER=auto se usa OpenAI si hay clave de
# OpenAI, y si no, Anthropic.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# AI_PROVIDER=auto      # auto | openai | anthropic
# AI_MODEL=             # vacío = por defecto: gpt-5-mini / claude-opus-4-8
# AI_DESCRIPTIONS=off   # desactivar la descripción IA de imágenes
# AI_ENRICH=off         # desactivar el enriquecimiento (knowledge_model.md)
